# Vibemate environment variables
# Copy this file to .env and fill in the values.
# Never commit .env to version control.

# ── LLM Providers ────────────────────────────────────────────────────────────
# Required for Anthropic Claude models (claude-sonnet-4-6, claude-haiku-4-5, etc.)
ANTHROPIC_API_KEY=

# Optional: OpenAI models (gpt-4o, gpt-4o-mini, o3-mini)
# OPENAI_API_KEY=

# Optional: Google Gemini models (gemini-2.5-flash, gemini-2.5-pro)
# GOOGLE_API_KEY=

# ── MCP Server ───────────────────────────────────────────────────────────────
# Secret used to sign auth tokens for the MCP server.
# Generate with: openssl rand -hex 32
JWT_SECRET=

# Port the MCP server listens on (default: 3000)
PORT=3000

# ── Vibemate Runtime ─────────────────────────────────────────────────────────
# Log level: debug | info | warn | error  (default: info)
VIBEMATE_LOG_LEVEL=info

# Agent type hint for telemetry attribution
# Values: claude-code | cursor | codex | kilocode | opencode | antigravity | openhands
VIBEMATE_AGENT_TYPE=claude-code

# Auth wait timeout in milliseconds (default: 30000)
# VIBEMATE_AUTH_WAIT_MS=30000
