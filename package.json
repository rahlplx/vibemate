{
  "name": "@vibemate/core",
  "version": "1.0.0",
  "description": "Unified AI Coding Agent Plugin Platform - Write Once, Run Anywhere",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "vibemate": "./dist/cli/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "ai",
    "coding-agent",
    "claude",
    "opencode",
    "cursor",
    "codex",
    "mcp",
    "okf",
    "context-engineering",
    "telemetry",
    "self-improving"
  ],
  "author": "vibemate",
  "license": "MIT",
  "dependencies": {
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "crypto-js": "^4.2.0",
    "glob": "^10.3.0",
    "inquirer": "^9.2.0",
    "ora": "^8.0.1",
    "yaml": "^2.4.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/crypto-js": "^4.2.0",
    "@types/inquirer": "^9.0.10",
    "@types/node": "^20.14.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.56.0",
    "typescript": "^5.5.0",
    "vitest": "^1.6.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
