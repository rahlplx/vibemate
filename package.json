{
  "name": "@vibemate/core",
  "version": "1.0.0",
  "description": "Unified AI Coding Agent Plugin Platform - Write Once, Run Anywhere",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "vibemate": "./dist/cli/index.js",
    "vibemate-mcp": "./dist/mcp/index.js"
  },
  "scripts": {
    "build": "bun build src/cli/index.ts --outdir ./dist/cli --target bun && bun build src/mcp/index.ts --outdir ./dist/mcp --target bun",
    "build:types": "tsc --emitDeclarationOnly",
    "build:mcp": "bun build src/mcp/index.ts --outdir ./dist --target bun",
    "dev": "bun --watch src/cli/index.ts",
    "dev:mcp": "bun --watch src/mcp/index.ts",
    "test": "bun test",
    "test:watch": "bun test --watch",
    "test:coverage": "bun test --coverage",
    "bench": "bun bench/benchmark.ts",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist",
    "prepublishOnly": "bun run build"
  },
  "keywords": [
    "ai",
    "coding-agent",
    "claude",
    "opencode",
    "cursor",
    "codex",
    "mcp",
    "okf",
    "context-engineering",
    "telemetry",
    "self-improving"
  ],
  "author": "vibemate",
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "@anthropic-ai/sdk": "^0.24.0",
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "glob": "^10.3.0",
    "hono": "^4.12.27",
    "inquirer": "^9.2.0",
    "ora": "^8.0.1",
    "yaml": "^2.4.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "@types/inquirer": "^9.0.10",
    "@types/node": "^20.14.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.56.0",
    "typescript": "^5.5.0"
  },
  "engines": {
    "node": ">=18.0.0",
    "bun": ">=1.0.0"
  }
}
